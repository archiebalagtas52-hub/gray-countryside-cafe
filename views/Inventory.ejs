<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventory Management</title>
    <link rel="stylesheet" href="/inventory.css">
    <script src="/script/session-manager.js"></script>
    <script src="/script/back-button-prevention.js"></script>

</head>
<body>
    <div id="toastContainer"></div>

    <div class="dashboard-container">
        <nav class="navbar">
            <div class="brandname">
                <div class="logo" onclick="openSettingsModal()" style="cursor: pointer; transition: transform 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                    <img src="/logo.png" alt="Logo" class="logo-img" title="Click to view settings">
                </div>
                <h2>Gray Countryside Cafe</h2>
            </div>
            <div class="logout-container">
                <button onclick="handleLogout()">Logout</button>
            </div>
        </nav>

        <div class="sidebar">
            <div class="search-section">
                <input type="text" class="search" placeholder="Search..">
            </div>
            
            <ul class="dashboard-menu">
                <li><a href="/admindashboard/dashboard" onclick="showSection('dashboard')" class="active">Dashboard</a></li>
                <li><a href="/admindashboard/Inventory">Inventory</a></li>
                <li><a href="/admindashboard/salesandreports">Sales Reports</a></li>
                <li><a href="/admindashboard/orderhistory">Order History</a></li>
                <li><a href="/admindashboard/addstaff">Add Staff</a></li>
                <li><a href="/admindashboard/menumanagement">Menu Management</a></li>
                <li><a href="/admindashboard/infosettings">Settings</a></li>
            </ul>
            <footer class="sidebar-footer">
                &copy; 2026 For School Purposes Only. All rights reserved.
            </footer>
        </div>

        <div class="main-content">
            <header class="header">
                <div class="logo-section">
                    <h1>Inventory Management</h1>
                </div>
            </header>

            <div class="container">
                <aside class="inventory-sidebar">
                    <div class="nav-section">
                        <ul class="nav-menu">
                            <li class="nav-item">
                                <a href="#" class="nav-link active" data-section="dashboard">
                                    <span class="nav-icon">Dashboard</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="#" class="nav-link" data-section="inventory">
                                    <span class="nav-icon">Inventory</span>
                                </a>
                                <div class="category-list">
                                    <div class="category-item active" data-category="all">All Raw Ingredients
                                        <span class="category-count">0</span>
                                    </div>
                                    <div class="category-item" data-category="meat">Meat & Poultry
                                        <span class="category-count">0</span>
                                    </div>
                                    <div class="category-item" data-category="seafood">Seafood
                                        <span class="category-count">0</span>
                                    </div>
                                    <div class="category-item" data-category="dairy">Dairy & Eggs
                                        <span class="category-count">0</span>
                                    </div>
                                    <div class="category-item" data-category="produce">Vegetables & Fruits
                                        <span class="category-count">0</span>
                                    </div>
                                    <div class="category-item" data-category="dry">Dry Goods
                                        <span class="category-count">0</span>
                                    </div>
                                    <div class="category-item" data-category="beverage">Beverages
                                        <span class="category-count">0</span>
                                    </div>  
                                    <div class="category-item" data-category="packaging">Packaging
                                        <span class="category-count">0</span>
                                    </div>            
                                </div>
                            </li>
                            <li class="nav-item">
                                <a href="#" class="nav-link" data-section="usage-management">
                                    <span class="nav-icon">Usage Management</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="#" class="nav-link" data-section="waste-management">
                                    <span class="nav-icon">Waste Management</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </aside>

                <main class="inventory-content">
                    <section class="section-content active-section" id="dashboard">
                        <div class="content-header">
                            <div class="content-title">
                                <h2>Inventory Dashboard</h2>
                            </div>                      
                        </div>

                        <div class="stats-dashboard">
                            <div class="stat-card">
                                <div>Total Raw Ingredients</div>
                                <h3>Total Raw Ingredients</h3>
                                <div class="stat-value" id="allInventoryItems">0</div>
                              
                            </div>
                            <div class="stat-card warning">
                                <div>Low Stock</div>
                                <h3>Low Stock Ingredients</h3>
                                <div class="stat-value" id="lowStock">0</div>
                               
                            </div>
                            <div class="stat-card critical">
                                <div>Out of Stock</div>
                                <h3>Out of Stock</h3>
                                <div class="stat-value" id="outOfStock">0</div>
                            
                            </div>
                             <div class="stat-card in-stock-stat">
                                <div>In Stock</div>
                                <h3>In Stock Ingredients</h3>
                                <div class="stat-value" id="inStock">0</div>
                                
                            </div>
                        </div>

                        <div class="inventory-grid" id="dashboardGrid"></div>
                    </section>

                    <section class="section-content" id="inventory">
                        <div class="content-header">
                            <div class="content-title">
                                <h2>Raw Ingredients</h2>
                            
                            </div>
                            <div class="action-buttons">
                                <button class="btn btn-primary" id="addNewItem">Add New Ingredient</button>
                            </div>
                        </div>

                        <div class="inventory-grid" id="inventoryGrid"></div>
                    </section>

                    <section class="section-content" id="usage-management">
                        <div class="content-header">
                            <div class="content-title">
                                <h2>Usage Management</h2>
                            </div>
                        </div>

                        <div class="stats-dashboard">
                            <div class="stat-card">
                                <div style="font-size: 24px; margin-bottom: 8px;">📊</div>
                                <h3 style="font-size: 13px; color: #666; margin-bottom: 8px;">Total Used</h3>
                                <div class="stat-value" id="totalUsage" style="color: #e74c3c;">0</div>
                                <p style="font-size: 11px; color: #999; margin-top: 5px;">units consumed</p>
                            </div>
                            <div class="stat-card info">
                                <div style="font-size: 24px; margin-bottom: 8px;">📅</div>
                                <h3 style="font-size: 13px; color: #666; margin-bottom: 8px;">This Month</h3>
                                <div class="stat-value" id="monthlyUsage" style="color: #3498db;">0</div>
                                <p style="font-size: 11px; color: #999; margin-top: 5px;">monthly usage</p>
                            </div>
                            <div class="stat-card warning">
                                <div style="font-size: 24px; margin-bottom: 8px;">⭐</div>
                                <h3 style="font-size: 13px; color: #666; margin-bottom: 8px;">Top Used</h3>
                                <div class="stat-value" id="topIngredient" style="color: #f39c12; font-size: 14px;">-</div>
                                <p style="font-size: 11px; color: #999; margin-top: 5px;">most consumed</p>
                            </div>
                        </div>

                        <div style="margin-top: 30px;">
                            <h3 style="margin-bottom: 15px; font-size: 16px; font-weight: 600;">Raw Ingredients Usage</h3>
                            <div class="table-container" style="overflow-x: auto;">
                                <table class="inventory-table" id="usageTable" style="width: 100%; border-collapse: collapse;">
                                    <thead>
                                        <tr style="background-color: #f5f5f5; border-bottom: 2px solid #ddd;">
                                            <th style="padding: 12px; text-align: left; font-weight: 600;">Ingredient Name</th>
                                            <th style="padding: 12px; text-align: center; font-weight: 600;">Category</th>
                                            <th style="padding: 12px; text-align: right; font-weight: 600;">Total Used</th>
                                            <th style="padding: 12px; text-align: right; font-weight: 600;">Unit</th>
                                            <th style="padding: 12px; text-align: right; font-weight: 600;">Current Stock</th>
                                            <th style="padding: 12px; text-align: center; font-weight: 600;">Last Used</th>
                                            <th style="padding: 12px; text-align: center; font-weight: 600;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="usageTableBody">
                                        <tr style="text-align: center; padding: 40px;">
                                            <td colspan="7" style="padding: 40px; color: #999;">
                                                <div style="font-size: 48px; margin-bottom: 15px;">📋</div>
                                                <h4>No Usage Records Yet</h4>
                                                <p style="font-size: 14px;">Raw ingredients usage will appear here when menu items are created</p>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </section>

                    <section class="section-content" id="waste-management">
                        <div class="content-header">
                            <div class="content-title">
                                <h2>Waste Management</h2>
                            </div>
                        </div>

                        <div class="stats-dashboard">
                            <div class="stat-card critical">
                                <div style="font-size: 24px; margin-bottom: 8px;"></div>
                                <h3 style="font-size: 13px; color: #666; margin-bottom: 8px;">Total Waste</h3>
                                <div class="stat-value" id="totalWaste" style="color: #e74c3c;">0</div>
                                <p style="font-size: 11px; color: #999; margin-top: 5px;">items damaged/expired</p>
                            </div>
                            <div class="stat-card warning">
                                <div style="font-size: 24px; margin-bottom: 8px;"></div>
                                <h3 style="font-size: 13px; color: #666; margin-bottom: 8px;">Waste Cost</h3>
                                <div class="stat-value" id="wasteCost" style="color: #f39c12;">₱0</div>
                                <p style="font-size: 11px; color: #999; margin-top: 5px;">estimated loss</p>
                            </div>
                            <div class="stat-card info">
                                <div style="font-size: 24px; margin-bottom: 8px;"></div>
                                <h3 style="font-size: 13px; color: #666; margin-bottom: 8px;">This Month</h3>
                                <div class="stat-value" id="monthlyWaste" style="color: #3498db;">0</div>
                                <p style="font-size: 11px; color: #999; margin-top: 5px;">monthly waste</p>
                            </div>
                        </div>

                        <div style="margin-top: 30px;">
                            <h3 style="margin-bottom: 15px; font-size: 16px; font-weight: 600;">Add Waste Item</h3>
                            <div style="background-color: #f9f9f9; padding: 20px; border-radius: 8px; margin-bottom: 30px; border: 1px solid #e0e0e0;">
                                <form id="addWasteForm" style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr auto; gap: 12px; align-items: flex-end;">
                                    <div>
                                        <label style="display: block; font-size: 12px; font-weight: 600; margin-bottom: 4px; color: #333;">Item Name</label>
                                        <select id="wasteItemName" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px;" required>
                                            <option value="">Select Item...</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label style="display: block; font-size: 12px; font-weight: 600; margin-bottom: 4px; color: #333;">Quantity</label>
                                        <input type="number" id="wasteQuantity" placeholder="0" min="0" step="0.01" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px;" required>
                                    </div>
                                    <div>
                                        <label style="display: block; font-size: 12px; font-weight: 600; margin-bottom: 4px; color: #333;">Unit Price (₱)</label>
                                        <input type="number" id="wasteUnitPrice" placeholder="0.00" min="0" step="0.01" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px;" required>
                                    </div>
                                    <div>
                                        <label style="display: block; font-size: 12px; font-weight: 600; margin-bottom: 4px; color: #333;">Status</label>
                                        <select id="wasteStatus" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; font-size: 13px;" required>
                                            <option value="">Select Status</option>
                                            <option value="rough">Rough</option>
                                            <option value="damaged">Damaged</option>
                                            <option value="expired">Expired</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                    <button type="button" class="btn btn-primary" onclick="recordWasteItem()" style="padding: 8px 12px; white-space: nowrap;">
                                        Add Item
                                    </button>
                                </form>
                            </div>

                            <h3 style="margin-bottom: 15px; font-size: 16px; font-weight: 600;">Rough & Expired Items</h3>
                            <div class="table-container" style="overflow-x: auto;">
                                <table class="inventory-table" id="wasteTable" style="width: 100%; border-collapse: collapse;">
                                    <thead>
                                        <tr style="background-color: #f5f5f5; border-bottom: 2px solid #ddd;">
                                            <th style="padding: 12px; text-align: left; font-weight: 600;">Item Name</th>
                                            <th style="padding: 12px; text-align: center; font-weight: 600;">Status</th>
                                            <th style="padding: 12px; text-align: right; font-weight: 600;">Quantity</th>
                                            <th style="padding: 12px; text-align: right; font-weight: 600;">Unit Price</th>
                                            <th style="padding: 12px; text-align: right; font-weight: 600;">Estimated Cost</th>
                                           
                                        </tr>
                                    </thead>
                                    <tbody id="wasteTableBody">
                                        <tr style="text-align: center; padding: 40px;">
                                            <td colspan="6" style="padding: 40px; color: #999;">
                                                <div style="font-size: 48px; margin-bottom: 15px;"></div>
                                                <h4>No Waste Records</h4>
                                                <p style="font-size: 14px;">All ingredients are in good condition</p>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </section>
                </main>
            </div>
        </div>
    </div>

    <div class="modal" id="itemModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modalTitle">Add New Raw Ingredient</h2>
                <button class="close" id="closeModal">&times;</button>
            </div>
            <!-- Duplicate Notification Badge -->
            <div id="duplicateNotification" class="duplicate-notification" style="display: none;">
                <span class="notification-icon">⚠️</span>
                <span class="notification-text"><strong id="duplicateIngredientName"></strong> already exists in your inventory</span>
                <span class="notification-action">Use the Edit button to update the existing ingredient</span>
            </div>
            <div class="modal-body">
                <form id="itemForm">
                    <!-- Row 1: Category & Ingredient Name -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="itemCategories">Category <span class="required">*</span></label>
                            <select id="itemCategories" class="form-control" required>
                                <option value="">Select Category</option>
                                <option value="meat">Meat & Poultry</option>
                                <option value="seafood">Seafood</option>
                                <option value="dairy">Dairy & Eggs</option>
                                <option value="produce">Vegetables & Fruits</option>
                                <option value="condiment">Condiments & Sauces</option>
                                <option value="oil">Oils & Vinegars</option>
                                <option value="dry">Dry Goods</option>
                                <option value="snacks">Snacks & Sides</option>
                                <option value="bakery">Bakery</option>
                                <option value="beverage">Beverages</option>
                                <option value="packaging">Packaging</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="itemName">Ingredient Name <span class="required">*</span></label>
                            <select id="itemName" class="form-control" required>
                                <option value="">Select Ingredient</option>
                                <!-- Meat & Poultry (meat) -->
                                <option value="Pork slices" data-category="meat">Pork slices</option>
                                <option value="Pork belly" data-category="meat">Pork belly</option>
                                <option value="Chicken" data-category="meat">Chicken</option>
                                <option value="Ground pork" data-category="meat">Ground pork</option>
                                <option value="Beef shanks" data-category="meat">Beef shanks</option>
                                <option value="Pork ribs" data-category="meat">Pork ribs</option>
                                <option value="Bacon" data-category="meat">Bacon</option>
                                <option value="Ham" data-category="meat">Ham</option>
                                
                                <!-- Seafood (seafood) -->
                                <option value="Cream dory fillet" data-category="seafood">Cream dory fillet</option>
                                <option value="Shrimp" data-category="seafood">Shrimp</option>
                                <option value="Smoked fish" data-category="seafood">Smoked fish</option>
                                
                                <!-- Dairy & Eggs (dairy) -->
                                <option value="Butter" data-category="dairy">Butter</option>
                                <option value="Eggs" data-category="dairy">Eggs</option>
                                <option value="Milk" data-category="dairy">Milk</option>
                                <option value="Cheese" data-category="dairy">Cheese</option>
                                
                                <!-- Vegetables & Fruits (produce) -->
                                <option value="Garlic" data-category="produce">Garlic</option>
                                <option value="Onion" data-category="produce">Onion</option>
                                <option value="Carrots" data-category="produce">Carrots</option>
                                <option value="Cabbage" data-category="produce">Cabbage</option>
                                <option value="Tomato" data-category="produce">Tomato</option>
                                <option value="Lettuce" data-category="produce">Lettuce</option>
                                <option value="Ginger" data-category="produce">Ginger</option>
                                <option value="Calamansi" data-category="produce">Calamansi</option>
                                <option value="Lemon" data-category="produce">Lemon</option>
                                <option value="Potato" data-category="produce">Potato</option>
                                
                                <!-- Dry Goods (dry) -->
                                <option value="Soy sauce" data-category="dry">Soy sauce</option>
                                <option value="Brown sugar" data-category="dry">Brown sugar</option>
                                <option value="Salt" data-category="dry">Salt</option>
                                <option value="Black pepper" data-category="dry">Black pepper</option>
                                <option value="Cooking oil" data-category="dry">Cooking oil</option>
                                <option value="Flour" data-category="dry">Flour</option>
                                <option value="Vinegar" data-category="dry">Vinegar</option>
                                <option value="Sugar" data-category="dry">Sugar</option>
                                <option value="Ice" data-category="dry">Ice</option>
                                <option value="Water" data-category="dry">Water</option>
                                
                                <!-- Beverages (beverage) -->
                                <option value="Sprite" data-category="beverage">Sprite</option>
                                <option value="Coke" data-category="beverage">Coke</option>
                                
                                <!-- Packaging (packaging) -->
                                <option value="Paper cups" data-category="packaging">Paper cups</option>
                                <option value="Straws" data-category="packaging">Straws</option>
                                <option value="Napkins" data-category="packaging">Napkins</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Row 2: Item Type & Unit -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="itemTypes">Item Type <span class="required">*</span></label>
                            <select id="itemTypes" class="form-control" required>
                                <option value="">Select Type</option>
                                <option value="raw">Raw Ingredient</option>   
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="itemUnit">Unit <span class="required">*</span></label>
                            <select id="itemUnit" class="form-control" required>
                                <option value="">Select Unit</option>
                                <option value="kg">Kilogram (kg)</option>
                                <option value="g">Gram (g)</option>
                                <option value="ml">Milliliter (ml)</option>
                                <option value="liters">Liters (L)</option>
                                <option value="pieces">Pieces</option>
                                <option value="packs">Packs</option>
                                <option value="bottles">Bottles</option>
                            </select> 
                        </div>
                    </div>
                    
                    <!-- Stock Fields Group -->
                    <div class="stock-fields-group">
                        <div class="stock-field">
                            <label for="currentStock">Current Stock</label>
                            <input type="number" id="currentStock" name="currentStock" class="form-control" min="0" step="0.01" value="0" required>
                            <span class="form-hint">Current quantity</span>
                        </div>
                        <div class="stock-field">
                            <label for="minStock">Min Stock</label>
                            <input type="number" id="minStock" name="minStock" class="form-control" min="0" step="0.01" value="10" required>
                            <span class="form-hint">Alert level</span>
                        </div>
                        <div class="stock-field">
                            <label for="maxStock">Max Stock</label>
                            <input type="number" id="maxStock" name="maxStock" class="form-control" min="0" step="0.01" value="50" required>
                            <span class="form-hint">Capacity</span>
                        </div>
                    </div>
                    
                    <!-- Description -->
                    <div class="form-group full-width">
                        <label for="description">Description (Optional)</label>
                        <textarea id="description" name="description" class="form-control" placeholder="Add notes about this ingredient..."></textarea>
                    </div>
                    
                    <input type="hidden" id="itemId">
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="cancelBtn">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveItemBtn">Save Ingredient</button>
            </div>
        </div>
    </div>


    <script src="/script/inventory-manager.js"></script>
    <script src="/script/inventory.js"></script>
    <script>
        // Mobile menu initialization
        (function() {
            function initMobileMenu() {
                const navbar = document.querySelector('.navbar') || document.querySelector('.header-navbar');
                if (!navbar) return;

                if (document.querySelector('.hamburger-menu')) return;

                const hamburger = document.createElement('div');
                hamburger.className = 'hamburger-menu';
                hamburger.id = 'hamburgerMenu';
                hamburger.innerHTML = '<span></span><span></span><span></span>';

                navbar.insertBefore(hamburger, navbar.firstChild);

                const overlay = document.createElement('div');
                overlay.className = 'sidebar-overlay';
                overlay.id = 'sidebarOverlay';
                document.body.appendChild(overlay);

                const sidebar = document.querySelector('.sidebar');
                if (!sidebar) return;

                const sidebarHeader = document.createElement('div');
                sidebarHeader.className = 'sidebar-header';
                sidebarHeader.innerHTML = `
                    <h3>Menu</h3>
                    <button class="sidebar-close" id="closeSidebar"></button>
                `;

                sidebar.insertBefore(sidebarHeader, sidebar.firstChild);

                function openMenu() {
                    hamburger.classList.add('active');
                    sidebar.classList.add('active');
                    overlay.classList.add('active');
                    document.body.classList.add('menu-open');
                }

                function closeMenu() {
                    hamburger.classList.remove('active');
                    sidebar.classList.remove('active');
                    overlay.classList.remove('active');
                    document.body.classList.remove('menu-open');
                }

                hamburger.addEventListener('click', function(e) {
                    e.stopPropagation();
                    if (sidebar.classList.contains('active')) {
                        closeMenu();
                    } else {
                        openMenu();
                    }
                });

                overlay.addEventListener('click', closeMenu);

                const closeBtn = document.getElementById('closeSidebar');
                if (closeBtn) {
                    closeBtn.addEventListener('click', closeMenu);
                }

                const menuItems = sidebar.querySelectorAll('ul.dashboard-menu li a, .sidebar .category-btn, .sidebar button');
                menuItems.forEach(item => {
                    item.addEventListener('click', function() {
                        menuItems.forEach(i => i.classList.remove('active'));
                        if (this.tagName === 'A') {
                            this.classList.add('active');
                        }
                        closeMenu();
                    });
                });

                const currentPath = window.location.pathname;
                const links = sidebar.querySelectorAll('ul.dashboard-menu li a');
                links.forEach(item => {
                    const href = item.getAttribute('href');
                    if (href && currentPath.includes(href)) {
                        item.classList.add('active');
                    }
                });

                window.addEventListener('resize', function() {
                    if (window.innerWidth > 768) {
                        if (sidebar.classList.contains('active')) {
                            closeMenu();
                        }
                        document.body.classList.remove('menu-open');
                    }
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initMobileMenu);
            } else {
                initMobileMenu();
            }
        })();

        // ==================== SETTINGS MODAL FUNCTIONS ====================
        function openSettingsModal() {
            const settingsModal = document.getElementById('settingsModal');
            settingsModal.style.display = 'flex';
            loadUserSettings();
        }

        function closeSettingsModal() {
            document.getElementById('settingsModal').style.display = 'none';
        }

        async function loadUserSettings() {
            try {
                const response = await fetch('/api/settings', {
                    headers: { 'Accept': 'application/json' },
                    credentials: 'include'
                });
                if (response.ok) {
                    const data = await response.json();
                    if (data.success && data.data) {
                        document.getElementById('settingsName').textContent = data.data.name || 'Not Set';
                        document.getElementById('settingsRole').textContent = data.data.role || 'Admin';
                    }
                }
            } catch (error) {
                console.error('Error loading user settings:', error);
            }
        }

        document.addEventListener('click', function(event) {
            const settingsModal = document.getElementById('settingsModal');
            if (settingsModal && event.target === settingsModal) {
                closeSettingsModal();
            }
        });
    </script>
</body>
</html>